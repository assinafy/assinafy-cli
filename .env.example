# Assinafy CLI environment variables (all optional — flags and config file also work)

# Preferred credential — sent as the X-Api-Key header.
ASSINAFY_API_KEY=

# Default workspace / account ID applied to account-scoped commands.
ASSINAFY_ACCOUNT_ID=

# Override the API base URL. Use the sandbox while testing:
#   https://sandbox.assinafy.com.br/v1
# Defaults to https://api.assinafy.com.br/v1
ASSINAFY_BASE_URL=

# Legacy JWT access token (sent as Authorization: Bearer). Prefer ASSINAFY_API_KEY.
ASSINAFY_TOKEN=

# Shared secret used to verify inbound webhook signatures.
ASSINAFY_WEBHOOK_SECRET=

# Named profile to select from the config file (~/.config/assinafy/config.json).
ASSINAFY_PROFILE=
